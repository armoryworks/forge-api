<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\forge.core\forge.core.csproj" />
    <ProjectReference Include="..\Forge.Platform\Forge.Platform.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Forge.Platform.Entities" />
    <Using Include="Forge.Platform.Time" />
  </ItemGroup>

  <ItemGroup>
<PackageReference Include="MailKit" Version="4.16.0" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.8" />
    <PackageReference Include="Microsoft.AspNetCore.DataProtection" Version="10.0.8" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.8" />
    <PackageReference Include="Minio" Version="7.0.0" />
<PackageReference Include="Microsoft.Playwright" Version="1.50.0" />
    <PackageReference Include="PuppeteerSharp" Version="24.39.0" />
    <PackageReference Include="SkiaSharp" Version="3.116.1" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux.NoDependencies" Version="3.116.1" />
    <PackageReference Include="PDFsharp" Version="6.2.4" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Forge.Integrations</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Skip auto-download of Playwright browsers — we provide ExecutablePath at runtime -->
    <PlaywrightSkipInstall>true</PlaywrightSkipInstall>
  </PropertyGroup>

</Project>

