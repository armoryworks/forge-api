FROM mcr.microsoft.com/dotnet/sdk:9.0
WORKDIR /app

# Install Chromium (PuppeteerSharp + Playwright fallback), ffmpeg, pwsh
RUN apt-get update && apt-get install -y --no-install-recommends \
    chromium \
    fonts-liberation \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    ffmpeg \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Pre-restore packages for layer caching (source is volume-mounted at runtime)
COPY forge.api/forge.api.csproj forge.api/
COPY forge.core/forge.core.csproj forge.core/
COPY forge.data/forge.data.csproj forge.data/
COPY forge.integrations/forge.integrations.csproj forge.integrations/
RUN dotnet restore forge.api/forge.api.csproj

# Install Playwright browsers (Chromium + ffmpeg) — persisted in layer
# Builds the project first so playwright.ps1 + Microsoft.Playwright.dll exist
COPY forge.api/ forge.api/
COPY forge.core/ forge.core/
COPY forge.data/ forge.data/
COPY forge.integrations/ forge.integrations/
COPY forge.tests/ forge.tests/
RUN dotnet build forge.api/forge.api.csproj -c Debug --no-restore \
    && pwsh forge.api/bin/Debug/net9.0/playwright.ps1 install chromium \
    && pwsh forge.api/bin/Debug/net9.0/playwright.ps1 install ffmpeg

EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080;http://+:5000
ENV DOTNET_USE_POLLING_FILE_WATCHER=true
ENV DOTNET_WATCH_RESTART_ON_RUDE_EDIT=true

ENTRYPOINT ["dotnet", "watch", "run", "--project", "forge.api", "--no-launch-profile"]
